generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth / Users ────────────────────────────────────────────────────────────

model User {
  id               String        @id @default(uuid())
  email            String        @unique
  displayName      String?       // Populated from Google OAuth full_name on first action
  createdAt        DateTime      @default(now())
  characters       Character[]
  partyMemberships PartyMember[]
}

// ─── Items ────────────────────────────────────────────────────────────────────

// stat_bonuses shape: { "strength": 2 } or { "strength": { "type": "override", "value": 19 } }
model Item {
  id          String   @id @default(uuid())
  name        String
  slotType    SlotType
  statBonuses Json     @default("{}")

  equippedAsMainHand Character[] @relation("CharacterMainHand")
  equippedAsOffHand  Character[] @relation("CharacterOffHand")
  equippedAsArmor    Character[] @relation("CharacterArmor")
  equippedAsRing     Character[] @relation("CharacterRing")
}

enum SlotType {
  WEAPON
  ARMOR
  SHIELD
  FOCUS
  RING
}

// ─── Character ────────────────────────────────────────────────────────────────

model Character {
  id             String        @id @default(uuid())
  name           String
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  characterClass String

  // Base ability scores — before equipment bonuses
  baseStrength     Int @default(8)
  baseDexterity    Int @default(8)
  baseConstitution Int @default(8)
  baseIntelligence Int @default(8)
  baseWisdom       Int @default(8)
  baseCharisma     Int @default(8)

  xp           Int @default(0)
  level        Int @default(1)
  maxHp        Int @default(10)
  currentHp    Int @default(10)
  skillProficiencies String[] @default([])

  // Equipment slots — nullable FK to Item
  mainHandId String?
  mainHand   Item?   @relation("CharacterMainHand", fields: [mainHandId], references: [id])
  offHandId  String?
  offHand    Item?   @relation("CharacterOffHand", fields: [offHandId], references: [id])
  armorId    String?
  armor      Item?   @relation("CharacterArmor", fields: [armorId], references: [id])
  ringId     String?
  ring       Item?   @relation("CharacterRing", fields: [ringId], references: [id])

  // Turn resource tracking — decremented during combat, reset each round.
  // Defaults match the universal base caps (1 action / 1 bonus / 30 ft).
  remainingActions      Int @default(1)
  remainingBonusActions Int @default(1)
  remainingMovementFeet Int @default(30)

  // Unequipped item IDs
  backpack String[] @default([])

  games            Game[]
  partyMemberships PartyMember[]
}

// ─── World Content (seeded) ───────────────────────────────────────────────────

model Map {
  id   String @id @default(uuid())
  name String @unique
  // { width, height, tiles[][], playerStart: {x,y}, rooms[], pois[] }
  data Json

  stories          StoryPrompt[]
  games            Game[]
  equippableItems  EquippableItem[]
}

model StoryPrompt {
  id          String @id @default(uuid())
  title       String @unique
  description String
  difficulty  String
  mapId       String
  map         Map    @relation(fields: [mapId], references: [id])

  games Game[]
}

// ─── Active Game ──────────────────────────────────────────────────────────────

model Game {
  id            String      @id @default(uuid())
  characterId   String      // The host character (created the game)
  character     Character   @relation(fields: [characterId], references: [id])
  storyPromptId String
  storyPrompt   StoryPrompt @relation(fields: [storyPromptId], references: [id])
  mapId         String
  map           Map         @relation(fields: [mapId], references: [id])
  status        GameStatus  @default(ACTIVE)

  // LOBBY = waiting for players to join; ACTIVE = playing; COMPLETED = done.
  // Default is ACTIVE so that legacy games (created before party system) work
  // without needing a migration to back-fill the column.
  phase GamePhase @default(ACTIVE)

  // Set by startAdventure when the game transitions from LOBBY → ACTIVE.
  // Advances after each turn following the DEX-ordered turn sequence.
  currentTurnCharacterId String?

  // World state JSON read/updated by the AI DM each turn.
  // Solo games: { playerPos, hp, maxHp, inventory, equipped, ... }
  // Party games: extends with { partyPositions, partyHp, partyMaxHp }
  state Json

  version Int @default(0) // optimistic lock counter — increment on every state write

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  messages     Message[]
  partyMembers PartyMember[]
  pendingRolls PendingRoll[]
}

enum GameStatus {
  ACTIVE
  PAUSED
  COMPLETED
}

enum GamePhase {
  LOBBY
  ACTIVE
  COMPLETED
}

// ─── Party ────────────────────────────────────────────────────────────────────

// One row per character in a game. Includes the host (created automatically
// when the game is created) and any players who join via the lobby URL.
model PartyMember {
  id          String       @id @default(uuid())
  gameId      String
  game        Game         @relation(fields: [gameId], references: [id])
  characterId String
  character   Character    @relation(fields: [characterId], references: [id])
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  status      MemberStatus @default(JOINED)
  // Assigned by startAdventure, sorted by DEX desc. 0 = goes first.
  turnOrder   Int          @default(0)
  joinedAt    DateTime     @default(now())
}

enum MemberStatus {
  JOINED
  READY
}

// ─── Message Log ──────────────────────────────────────────────────────────────

model Message {
  id      String      @id @default(uuid())
  gameId  String
  game    Game        @relation(fields: [gameId], references: [id])
  role    MessageRole
  content String
  // AI-generated action chips; only on DUNGEON_MASTER messages.
  chips   Json?

  createdAt DateTime @default(now())
}

enum MessageRole {
  PLAYER
  DUNGEON_MASTER
}

// ─── Equippable Items ─────────────────────────────────────────────────────────

// Loot available in a given map. Seeded per-map; instances are referenced by
// the game's inventory JSON when a player picks one up.
model EquippableItem {
  id                String  @id @default(uuid())
  mapId             String
  map               Map     @relation(fields: [mapId], references: [id], onDelete: Cascade)

  name              String
  category          String  // "Weapon" | "Armor" | "Consumable" | "Held"
  description       String  @default("")
  weightLbs         Float
  quantity          Int     @default(1)
  isEquipped        Boolean @default(false)
  combatImpactLabel String  // e.g. "+5 Damage", "+2 AC", "Heal 8 HP"

  @@index([mapId])
}

// ─── Class Progression ───────────────────────────────────────────────────────

// Lookup table: one row per (characterClass, level) pair, levels 1–20.
// Logical link to Character: JOIN ON characterClass = Character.characterClass
//                                AND level = Character.level
model ClassProgression {
  id               String @id @default(uuid())
  characterClass   String           // "Fighter" | "Rogue" | "Cleric" | "Wizard"
  level            Int              // 1–20
  proficiencyBonus Int
  featuresUnlocked String[]         // feature name slugs unlocked at this level
  resourcePoolMax  Int?             // spell slots, rage charges, etc. (null = none)

  features ClassFeature[]

  @@unique([characterClass, level])
  @@index([characterClass])
}

// ─── Class Feature ───────────────────────────────────────────────────────────

// Detail record for a single feature unlocked at a given class + level.
model ClassFeature {
  id             String @id @default(uuid())
  characterClass String
  level          Int
  name           String
  description    String
  icon           String           @default("🍃") // Default passive/free icon
  costType       String           @default("free") // Default to free action to avoid breaking existing code

  classProgression ClassProgression @relation(fields: [characterClass, level], references: [characterClass, level])

  @@index([characterClass, level])
}

// ─── Server-Seeded Roll ───────────────────────────────────────────────────────

// Short-lived record that binds a rollRequestId to a crypto-secure d20 result.
// Written by /api/rolls/secure-seed; read when the turn is resolved.
// TTL of 5 minutes enforced by expiresAt (purged on resolution).
model PendingRoll {
  id        String   @id @default(uuid())
  requestId String   @unique             // rollRequestId from buildRollContext
  gameId    String
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  d20       Int                          // 1–20, rejection-sampled from crypto.getRandomValues
  createdAt DateTime @default(now())
  expiresAt DateTime                     // now + 5 min

  @@index([gameId])
}
