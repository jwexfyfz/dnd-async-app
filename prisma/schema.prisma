generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth / Users ────────────────────────────────────────────────────────────

model User {
  id               String        @id @default(uuid())
  email            String        @unique
  displayName      String?       // Populated from Google OAuth full_name on first action
  createdAt        DateTime      @default(now())
  characters       Character[]
  partyMemberships PartyMember[]
}

// ─── Character ────────────────────────────────────────────────────────────────

model Character {
  id             String        @id @default(uuid())
  name           String
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  characterClass String

  strength     Int @default(8)
  dexterity    Int @default(8)
  constitution Int @default(8)
  intelligence Int @default(8)
  wisdom       Int @default(8)
  charisma     Int @default(8)
  xp           Int @default(0)
  level        Int @default(1)
  maxHp        Int @default(10)
  currentHp    Int @default(10)

  games            Game[]
  partyMemberships PartyMember[]
}

// ─── World Content (seeded) ───────────────────────────────────────────────────

model Map {
  id   String @id @default(uuid())
  name String @unique
  // { width, height, tiles[][], playerStart: {x,y}, rooms[], pois[] }
  data Json

  stories          StoryPrompt[]
  games            Game[]
  equippableItems  EquippableItem[]
}

model StoryPrompt {
  id          String @id @default(uuid())
  title       String @unique
  description String
  difficulty  String
  mapId       String
  map         Map    @relation(fields: [mapId], references: [id])

  games Game[]
}

// ─── Active Game ──────────────────────────────────────────────────────────────

model Game {
  id            String      @id @default(uuid())
  characterId   String      // The host character (created the game)
  character     Character   @relation(fields: [characterId], references: [id])
  storyPromptId String
  storyPrompt   StoryPrompt @relation(fields: [storyPromptId], references: [id])
  mapId         String
  map           Map         @relation(fields: [mapId], references: [id])
  status        GameStatus  @default(ACTIVE)

  // LOBBY = waiting for players to join; ACTIVE = playing; COMPLETED = done.
  // Default is ACTIVE so that legacy games (created before party system) work
  // without needing a migration to back-fill the column.
  phase GamePhase @default(ACTIVE)

  // Set by startAdventure when the game transitions from LOBBY → ACTIVE.
  // Advances after each turn following the DEX-ordered turn sequence.
  currentTurnCharacterId String?

  // World state JSON read/updated by the AI DM each turn.
  // Solo games: { playerPos, hp, maxHp, inventory, equipped, ... }
  // Party games: extends with { partyPositions, partyHp, partyMaxHp }
  state Json

  version Int @default(0) // optimistic lock counter — increment on every state write

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  messages     Message[]
  partyMembers PartyMember[]
}

enum GameStatus {
  ACTIVE
  PAUSED
  COMPLETED
}

enum GamePhase {
  LOBBY
  ACTIVE
  COMPLETED
}

// ─── Party ────────────────────────────────────────────────────────────────────

// One row per character in a game. Includes the host (created automatically
// when the game is created) and any players who join via the lobby URL.
model PartyMember {
  id          String       @id @default(uuid())
  gameId      String
  game        Game         @relation(fields: [gameId], references: [id])
  characterId String
  character   Character    @relation(fields: [characterId], references: [id])
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  status      MemberStatus @default(JOINED)
  // Assigned by startAdventure, sorted by DEX desc. 0 = goes first.
  turnOrder   Int          @default(0)
  joinedAt    DateTime     @default(now())
}

enum MemberStatus {
  JOINED
  READY
}

// ─── Message Log ──────────────────────────────────────────────────────────────

model Message {
  id      String      @id @default(uuid())
  gameId  String
  game    Game        @relation(fields: [gameId], references: [id])
  role    MessageRole
  content String
  // AI-generated action chips; only on DUNGEON_MASTER messages.
  chips   Json?

  createdAt DateTime @default(now())
}

enum MessageRole {
  PLAYER
  DUNGEON_MASTER
}

// ─── Equippable Items ─────────────────────────────────────────────────────────

// Loot available in a given map. Seeded per-map; instances are referenced by
// the game's inventory JSON when a player picks one up.
model EquippableItem {
  id                String  @id @default(uuid())
  mapId             String
  map               Map     @relation(fields: [mapId], references: [id], onDelete: Cascade)

  name              String
  category          String  // "Weapon" | "Armor" | "Consumable"
  weightLbs         Float
  quantity          Int     @default(1)
  isEquipped        Boolean @default(false)
  combatImpactLabel String  // e.g. "+5 Damage", "+2 AC", "Heal 8 HP"

  @@index([mapId])
}

// ─── Class Progression ───────────────────────────────────────────────────────

// Lookup table: one row per (characterClass, level) pair, levels 1–20.
// Logical link to Character: JOIN ON characterClass = Character.characterClass
//                                AND level = Character.level
model ClassProgression {
  id               String @id @default(uuid())
  characterClass   String           // "Fighter" | "Rogue" | "Cleric" | "Wizard"
  level            Int              // 1–20
  proficiencyBonus Int
  featuresUnlocked String[]         // feature name slugs unlocked at this level
  resourcePoolMax  Int?             // spell slots, rage charges, etc. (null = none)

  features ClassFeature[]

  @@unique([characterClass, level])
  @@index([characterClass])
}

// ─── Class Feature ───────────────────────────────────────────────────────────

// Detail record for a single feature unlocked at a given class + level.
model ClassFeature {
  id             String @id @default(uuid())
  characterClass String
  level          Int
  name           String
  description    String

  classProgression ClassProgression @relation(fields: [characterClass, level], references: [characterClass, level])

  @@index([characterClass, level])
}
