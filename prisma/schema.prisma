generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth / Users ────────────────────────────────────────────────────────────

model User {
  id               String        @id @default(uuid())
  email            String        @unique
  displayName      String?
  createdAt        DateTime      @default(now())
  characters       Character[]
  partyMemberships PartyMember[]
}

// ─── Items ────────────────────────────────────────────────────────────────────

model Item {
  id                String  @id @default(uuid())
  name              String
  type              String  @default("")

  statKey           String?
  statModifierBonus Int     @default(0)

  mapId             String?
  map               Map?    @relation(fields: [mapId], references: [id], onDelete: Cascade)
  category          String  @default("")
  description       String  @default("")
  weightLbs         Float   @default(0)
  quantity          Int     @default(1)
  isEquipped        Boolean @default(false)
  combatImpactLabel String  @default("")

  posX  Int?
  posY  Int?

  // Locked until a scene activates (null = visible from act start)
  activeFromSceneId String?
  activeFromScene   Scene?  @relation("SceneLockedItems", fields: [activeFromSceneId], references: [id])

  // Enemy loot — appears on the enemy's tile when defeated
  enemyId String?
  enemy   Enemy?  @relation("EnemyLoot", fields: [enemyId], references: [id])

  equippedAsMainHand Character[] @relation("CharacterMainHand")
  equippedAsOffHand  Character[] @relation("CharacterOffHand")
  equippedAsArmor    Character[] @relation("CharacterArmor")
  equippedAsRing     Character[] @relation("CharacterRing")

  @@index([mapId])
}

// ─── Character ────────────────────────────────────────────────────────────────

model Character {
  id             String        @id @default(uuid())
  name           String
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  characterClass String

  baseStrength     Int @default(8)
  baseDexterity    Int @default(8)
  baseConstitution Int @default(8)
  baseIntelligence Int @default(8)
  baseWisdom       Int @default(8)
  baseCharisma     Int @default(8)

  xp           Int @default(0)
  level        Int @default(1)
  maxHp        Int @default(10)
  currentHp    Int @default(10)
  skillProficiencies String[] @default([])

  mainHandId String?
  mainHand   Item?   @relation("CharacterMainHand", fields: [mainHandId], references: [id])
  offHandId  String?
  offHand    Item?   @relation("CharacterOffHand", fields: [offHandId], references: [id])
  armorId    String?
  armor      Item?   @relation("CharacterArmor", fields: [armorId], references: [id])
  ringId     String?
  ring       Item?   @relation("CharacterRing", fields: [ringId], references: [id])

  remainingActions      Int @default(1)
  remainingBonusActions Int @default(1)
  remainingMovementFeet Int @default(30)
  remainingReactions    Int @default(1)
  hasCastedBonusSpell   Boolean  @default(false)

  activeConditions String[] @default([])
  backpack String[] @default([])

  games            Game[]
  partyMemberships PartyMember[]
}

// ─── Story / Act / Scene ──────────────────────────────────────────────────────

model Story {
  id          String @id @default(uuid())
  title       String @unique
  description String // Short blurb shown in game selection
  difficulty  String @default("Standard") // Beginner | Standard | Veteran

  acts  Act[]
  games Game[]
}

model Act {
  id                      String @id @default(uuid())
  storyId                 String
  story                   Story  @relation(fields: [storyId], references: [id])
  order                   Int    // 1-based within the story
  title                   String
  summary                 String // Always fed to AI DM — enables foreshadowing
  playerFacingDescription String // Shown to players when act begins

  map     Map?
  scenes  Scene[]
  enemies Enemy[]
  games   Game[]

  @@unique([storyId, order])
  @@index([storyId])
}

model Scene {
  id          String   @id @default(uuid())
  actId       String
  act         Act      @relation(fields: [actId], references: [id])
  order       Int      // 1-based within the act
  title       String
  description String   // Full scene brief fed to AI DM on entry
  objectives  String[]

  // Scene 1 of each act uses ACT_START; others require a trigger.
  triggerType      SceneTriggerType
  triggerEnemyId   String? // ENEMY_DEFEATED: enemy id whose death fires this
  triggerItemId    String? // ITEM_FOUND: item id pickup that fires this
  triggerAreaX     Int?    // AREA_REACHED: tile x
  triggerAreaY     Int?    // AREA_REACHED: tile y
  triggerTurnLimit Int?    // TURN_LIMIT: AI forces progression after N scene turns

  // Written by AI when scene ends; replaces full message log for past-scene context
  summary     String?
  completedAt DateTime?

  enemies  Enemy[]
  items    Item[]    @relation("SceneLockedItems")
  messages Message[]
  games    Game[]

  @@unique([actId, order])
  @@index([actId])
}

model Enemy {
  id      String @id @default(uuid())
  actId   String
  act     Act    @relation(fields: [actId], references: [id])
  sceneId String // activates when this scene starts
  scene   Scene  @relation(fields: [sceneId], references: [id])

  name        String
  description String @default("")

  maxHp        Int
  currentHp    Int
  strength     Int    @default(10)
  dexterity    Int    @default(10)
  constitution Int    @default(10)
  intelligence Int    @default(10)
  wisdom       Int    @default(10)
  charisma     Int    @default(10)

  armorClass  Int    @default(10)
  attackBonus Int    @default(0)
  damageDice  String // e.g. "1d6+2"

  posX Int
  posY Int

  status    EnemyStatus @default(DORMANT)
  lootItems Item[]      @relation("EnemyLoot")

  @@index([actId])
  @@index([sceneId])
}

enum SceneTriggerType {
  ACT_START      // auto-fires when act begins (always used for scene 1)
  AREA_REACHED   // any party member steps on triggerAreaX/Y
  ENEMY_DEFEATED // triggerEnemyId is killed
  ITEM_FOUND     // triggerItemId is picked up
  TURN_LIMIT     // AI DM forces transition after triggerTurnLimit turns
}

enum EnemyStatus {
  DORMANT   // future scene — hidden from players and AI context
  ACTIVE    // current scene — visible and targetable
  DEFEATED
  FLED
}

// ─── Map ─────────────────────────────────────────────────────────────────────

model Map {
  id   String @id @default(uuid())
  name String @unique
  // { width, height, tiles[][], playerStart: {x,y}, rooms[], pois[] }
  data Json

  actId String? @unique // one map per act
  act   Act?    @relation(fields: [actId], references: [id])

  games Game[]
  items Item[]
}

// ─── Active Game ──────────────────────────────────────────────────────────────

model Game {
  id          String    @id @default(uuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id])

  storyId String?
  story   Story?  @relation(fields: [storyId], references: [id])

  currentActId String?
  currentAct   Act?    @relation(fields: [currentActId], references: [id])

  currentSceneId String?
  currentScene   Scene?  @relation(fields: [currentSceneId], references: [id])

  mapId String
  map   Map    @relation(fields: [mapId], references: [id])

  status GameStatus @default(ACTIVE)
  phase  GamePhase  @default(ACTIVE)

  currentTurnCharacterId String?

  state Json
  version Int @default(0)

  worldState           Json?
  narrativeHistory     String[] @default([])
  activeSuggestionChips Json?

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  messages         Message[]
  partyMembers     PartyMember[]
  pendingRolls     PendingRoll[]
  activeTurnQueues ActiveTurnQueue[]
  gameInventory    GameInventory[]
}

enum GameStatus {
  ACTIVE
  PAUSED
  COMPLETED
}

enum GamePhase {
  LOBBY
  ACTIVE
  COMPLETED
}

// ─── Party ────────────────────────────────────────────────────────────────────

model PartyMember {
  id          String       @id @default(uuid())
  gameId      String
  game        Game         @relation(fields: [gameId], references: [id])
  characterId String
  character   Character    @relation(fields: [characterId], references: [id])
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  status      MemberStatus @default(JOINED)
  turnOrder   Int          @default(0)
  joinedAt    DateTime     @default(now())

  posX Int @default(0)
  posY Int @default(0)
}

enum MemberStatus {
  JOINED
  READY
}

// ─── Message Log ──────────────────────────────────────────────────────────────

model Message {
  id      String      @id @default(uuid())
  gameId  String
  game    Game        @relation(fields: [gameId], references: [id])
  role    MessageRole
  content String
  chips   Json?

  // Scoped to the active scene when written — enables per-scene context windowing
  sceneId String?
  scene   Scene?  @relation(fields: [sceneId], references: [id])

  createdAt DateTime @default(now())
}

enum MessageRole {
  PLAYER
  DUNGEON_MASTER
}

// ─── Class Progression ───────────────────────────────────────────────────────

model ClassProgression {
  id               String @id @default(uuid())
  characterClass   String
  level            Int
  proficiencyBonus Int
  featuresUnlocked String[]
  resourcePoolMax  Int?

  features ClassFeature[]

  @@unique([characterClass, level])
  @@index([characterClass])
}

// ─── Class Feature ───────────────────────────────────────────────────────────

model ClassFeature {
  id             String @id @default(uuid())
  characterClass String
  level          Int
  name           String
  description    String
  icon           String @default("🍃")
  costType       String @default("free")

  classProgression ClassProgression @relation(fields: [characterClass, level], references: [characterClass, level])

  @@index([characterClass, level])
}

// ─── Active Turn Queue ────────────────────────────────────────────────────────

model ActiveTurnQueue {
  id               String          @id @default(uuid())
  gameId           String
  game             Game            @relation(fields: [gameId], references: [id], onDelete: Cascade)
  characterId      String
  status           TurnQueueStatus @default(PENDING_ROLLS)
  currentRollIndex Int             @default(0)
  rolls            Json
  createdAt        DateTime        @default(now())
  expiresAt        DateTime

  @@index([gameId])
}

enum TurnQueueStatus {
  PENDING_ROLLS
  COMPLETED
}

// ─── Game Inventory ───────────────────────────────────────────────────────────

model GameInventory {
  id       String @id @default(uuid())
  gameId   String
  game     Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  itemName String
  quantity Int    @default(1)

  @@index([gameId])
}

// ─── Server-Seeded Roll ───────────────────────────────────────────────────────

model PendingRoll {
  id        String   @id @default(uuid())
  requestId String   @unique
  gameId    String
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  d20       Int
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([gameId])
}
